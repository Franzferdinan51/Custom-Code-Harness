# =====================================================================
# CodingHarness environment variables
# Copy to .env and fill in the keys you want to use.
# Any value set here is loaded as a fallback when settings.json has no
# explicit value. Settings.json always wins.
# =====================================================================

# --- OpenAI (and any OpenAI-compatible: OpenRouter, LM Studio, vLLM) ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# --- Anthropic ---
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5

# --- Google Gemini (via OpenAI-compat endpoint) ---
# GEMINI_API_KEY=...
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# GEMINI_MODEL=gemini-2.0-flash

# --- CodingHarness behavior ---
# CH_HOME=~/.codingharness            # Override config directory
# CH_DEFAULT_PROVIDER=openai           # openai | anthropic
# CH_DEBUG=1                          # Verbose logging
# CH_MAX_CONTEXT_TOKENS=128000         # Soft cap; compaction triggers earlier
