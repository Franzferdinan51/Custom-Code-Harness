{
  "name": "codingharness",
  "version": "0.2.0",
  "description": "A versatile terminal coding harness — multi-provider, extensible, crash-resistant.",
  "type": "module",
  "private": true,
  "bin": {
    "ch": "./bin/ch"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "start": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "tsx --test src/__tests__/*.test.ts",
    "test:smoke": "tsx src/__tests__/smoke.ts"
  },
  "engines": {
    "node": ">=18.17"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {}
}
