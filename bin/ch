#!/usr/bin/env bash
# Launcher for CodingHarness.
# Prefers bun (required by @opentui/core for native FFI), falls back
# to node with the compiled dist/ if bun isn't available.

set -e
HERE="$(cd "$(dirname "$0")" && pwd)"

# Resolve symlinks (npm link creates one in /Users/duckets/.npm-global/bin/).
if [ -L "$0" ]; then
  TARGET="$(readlink -f "$0" 2>/dev/null || readlink "$0")"
  if [ -n "$TARGET" ] && [ -f "$TARGET" ]; then
    HERE="$(cd "$(dirname "$TARGET")" && pwd)"
  fi
fi

ROOT="$(cd "$HERE/.." && pwd)"

DIST="$ROOT/dist/cli.js"
SRC="$ROOT/src/cli.ts"

# Prefer bun if available (needed for @opentui/core's native FFI binding).
if command -v bun >/dev/null 2>&1; then
  if [ -f "$DIST" ]; then
    exec bun "$DIST" "$@"
  else
    exec bun --import tsx "$SRC" "$@"
  fi
else
  if [ -f "$DIST" ]; then
    exec node "$DIST" "$@"
  else
    exec node --import tsx "$SRC" "$@"
  fi
fi
